# Resend API key for contact form emails
# Get yours at https://resend.com
RESEND_API_KEY=

# Email address that receives contact form submissions
CONTACT_RECIPIENT_EMAIL=hello@eclat.co.uk

# Analytics (optional — only loaded after cookie consent)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Base URL (used for sitemap and OG tags)
NEXT_PUBLIC_BASE_URL=https://eclat.co.uk

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Dashboard demo credentials (mock data layer — no real machine connection needed)
# bar@demo.eclat.co.uk / demo-bar-pass   → venue-001 (The Alchemist)
# hotel@demo.eclat.co.uk / demo-hotel-pass → venue-002 (King Street Hotel)
# club@demo.eclat.co.uk / demo-club-pass  → venue-003 (Warehouse Project)

# ─── Future: Real machine API ─────────────────────────────────────────────────
# Uncomment when switching from MockDataSource to ApiDataSource
# See README.md → "How to connect the real machine API"
# MACHINE_API_URL=https://api.eclat-machines.co.uk
# MACHINE_API_KEY=

# ─── Future: OAuth SSO providers ─────────────────────────────────────────────
# Uncomment and add provider credentials to auth.ts to enable SSO login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
